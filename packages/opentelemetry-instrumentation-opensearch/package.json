{
  "name": "@sebspark/opentelemetry-instrumentation-opensearch",
  "version": "0.2.1",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "spark-build src/index.ts",
    "dev": "tsc --watch --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests --coverage",
    "test:e2e": "vitest --config vitest.config.e2e.ts --run",
    "typecheck": "vitest --typecheck.only --passWithNoTests"
  },
  "peerDependencies": {
    "@opensearch-project/opensearch": ">=2",
    "@opentelemetry/api": ">=1.9.0"
  },
  "dependencies": {
    "@opentelemetry/core": "2.6.0",
    "@opentelemetry/instrumentation": "0.213.0",
    "@opentelemetry/semantic-conventions": "1.40.0"
  },
  "devDependencies": {
    "@opensearch-project/opensearch": "3.5.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/instrumentation-http": "0.214.0",
    "@opentelemetry/instrumentation-undici": "0.23.0",
    "@opentelemetry/sdk-trace-base": "2.6.0",
    "@opentelemetry/sdk-trace-node": "2.6.0",
    "@testcontainers/opensearch": "11.13.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seb-oss/Spark-packages.git"
  }

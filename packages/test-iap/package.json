{
  "name": "@sebspark/test-iap",
  "version": "1.0.20",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "spark-build src/index.ts src/start.ts",
    "dev": "tsc --watch --noEmit",
    "lint": "biome check .",
    "test": "vitest run --passWithNoTests --coverage",
    "pretest:e2e": "yarn build",
    "test:e2e": "vitest --config vitest.config.e2e.ts --run",
    "typecheck": "vitest --typecheck.only --passWithNoTests"
  },
  "dependencies": {
    "jose": "6.2.3",
    "testcontainers": "12.0.1"
  },
  "devDependencies": {
    "@types/ws": "8.18.1",
    "nock": "15.0.0",
    "ws": "8.21.0"
  },
  "resolutions": {
    "protobufjs": "8.6.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seb-oss/Spark-packages.git"
  }
}

{
  "source": [
    "package.json",
    "packages/*/package.json",
    "apps/*/package.json"
  ],
  "versionGroups": [
    {
      "label": "Ignore semver rules for internal @sebspark packages",
      "dependencies": ["@sebspark/*"],
      "dependencyTypes": ["dev", "prod"],
      "isIgnored": true
    },
    {
      "label": "Ignore peer dependencies",
      "dependencyTypes": ["peer"],
      "dependencies": ["**"],
      "isIgnored": true
    }
  ],
  "semverGroups": [
    {
      "label": "Peer dependencies may use ranges",
      "dependencyTypes": ["peer"],
      "dependencies": ["**"],
      "packages": ["**"],
      "isIgnored": true
    },
    {
      "label": "All external dependencies must be exact",
      "range": "",
      "dependencies": ["**"],
      "packages": ["**"]
    }
  ]
}

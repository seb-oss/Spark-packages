{
  "name": "sebspark",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "check-upgrades": "node ./tools/check-upgrades.mjs && yarn upgrade-interactive",
    "clean": "rm -rf ./packages/**/dist",
    "depcheck": "turbo depcheck",
    "dev": "turbo dev",
    "format": "biome format --write",
    "generate:avro": "turbo generate:avro",
    "generate:package": "turbo gen package",
    "lint:watch": "turbo watch lint",
    "lint:write": "biome check --write",
    "knip": "knip",
    "lint": "node ./tools/check-no-dist-imports.mjs && turbo lint",
    "release": "turbo build && npx changeset publish",
    "smoketest": "yarn syncpack && yarn depcheck && yarn format && yarn lint && yarn build && yarn depcheck && yarn test",
    "start": "turbo watch lint test typecheck",
    "syncpack": "syncpack lint",
    "test:watch": "turbo watch test",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:e2e:watch": "turbo watch test:e2e",
    "typecheck": "turbo typecheck",
    "version-packages": "changeset version && yarn install --no-immutable",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@changesets/cli": "2.31.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@sebspark/tsconfig": "*",
    "@turbo/gen": "2.9.18",
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "depcheck": "1.4.7",
    "husky": "9.1.7",
    "knip": "6.21.0",
    "syncpack": "15.3.2",
    "tsup": "8.5.1",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "resolutions": {
    "protobufjs": "8.6.3",
    "rollup": "4.61.1",
    "minimatch@^5.1.0": "5.1.9",
    "minimatch@^7.4.6": "7.4.9",
    "minimatch@^9.0.4": "9.0.9",
    "minimatch@^10.1.1": "10.2.5",
    "fast-uri@^3.0.1": "3.1.2",
    "uuid@^11.1.0": "11.1.1",
    "@tootallnate/once@npm:2": "3.0.1",
    "yaml@^2.0.0": "2.9.0",
    "yaml@^2.2.2": "2.9.0",
    "yaml@^2.8.2": "2.9.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}

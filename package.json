{
  "name": "sebspark",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "check-upgrades": "node ./tools/check-upgrades.mjs && yarn upgrade-interactive",
    "clean": "rm -rf ./packages/**/dist",
    "depcheck": "turbo depcheck",
    "dev": "turbo dev",
    "format": "biome format --write",
    "generate:avro": "turbo generate:avro",
    "generate:package": "turbo gen package",
    "lint:watch": "turbo watch lint",
    "lint:write": "biome check --write",
    "knip": "knip",
    "lint": "node ./tools/check-no-dist-imports.mjs && turbo lint",
    "release": "turbo build && npx changeset publish",
    "smoketest": "yarn syncpack && yarn depcheck && yarn format && yarn lint && yarn build && yarn depcheck && yarn test",
    "start": "turbo watch lint test typecheck",
    "syncpack": "syncpack lint",
    "test:watch": "turbo watch test",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:e2e:watch": "turbo watch test:e2e",
    "typecheck": "turbo typecheck",
    "version-packages": "changeset version && yarn install --no-immutable",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@changesets/cli": "2.31.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@sebspark/tsconfig": "*",
    "@turbo/gen": "2.10.2",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "depcheck": "1.4.7",
    "husky": "9.1.7",
    "knip": "6.23.0",
    "syncpack": "15.3.2",
    "tsup": "8.5.1",
    "turbo": "2.10.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "resolutions": {
    "@babel/core": "7.29.7",
    "@opentelemetry/core@2.2.0": "2.8.0",
    "@opentelemetry/core@^2.0.0": "2.8.0",
    "@tootallnate/once@npm:2": "3.0.1",
    "fast-uri@^3.0.1": "3.1.3",
    "form-data@^2.5.5": "2.5.6",
    "form-data@^4.0.0": "4.0.6",
    "form-data@^4.0.5": "4.0.6",
    "minimatch@^5.1.0": "5.1.9",
    "minimatch@^7.4.6": "7.4.9",
    "minimatch@^9.0.4": "9.0.9",
    "minimatch@^10.1.1": "10.2.5",
    "protobufjs": "8.6.5",
    "qs": "6.15.3",
    "rollup": "4.62.2",
    "tar": "7.5.19",
    "vite": "8.1.2",
    "ws": "8.21.0",
    "yaml@^2.0.0": "2.9.0",
    "yaml@^2.2.2": "2.9.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae"
}
